exports[`preset snapshot validation > climate-full.json > passes MonitorForgeConfigSchema.parse() and matches snapshot 1`] = `
{
  "ai": {
    "analysis": {
      "customPrompt": "Focus on climate change developments, extreme weather events, natural disasters, environmental policy, and emissions data. Highlight escalating climate risks and international climate negotiations.",
      "entityExtraction": true,
      "focalPointDetection": true,
      "sentimentAnalysis": true,
      "summarization": true,
    },
    "enabled": true,
    "fallbackChain": [
      "groq",
      "openrouter",
    ],
    "providers": {
      "groq": {
        "apiKeyEnv": "GROQ_API_KEY",
        "model": "llama-3.3-70b-versatile",
      },
      "openrouter": {
        "apiKeyEnv": "OPENROUTER_API_KEY",
        "model": "anthropic/claude-sonnet-4",
      },
    },
  },
  "backend": {
    "cache": {
      "provider": "memory",
      "ttlSeconds": 300,
    },
    "corsProxy": {
      "allowedDomains": [
        "*",
      ],
      "corsOrigins": [
        "*",
      ],
      "enabled": true,
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowSeconds": 60,
    },
  },
  "build": {
    "outDir": "dist",
    "target": "vercel",
  },
  "layers": [
    {
      "category": "hazards",
      "color": "#FF6600",
      "data": {
        "path": "data/geo/natural-disasters.geojson",
        "source": "static",
      },
      "defaultVisible": true,
      "displayName": "Disaster Risk Zones",
      "name": "disaster-zones",
      "type": "heatmap",
    },
  ],
  "map": {
    "atmosphericGlow": true,
    "center": [
      0,
      20,
    ],
    "dayNightOverlay": true,
    "idleRotation": true,
    "idleRotationSpeed": 0.3,
    "maxZoom": 18,
    "minZoom": 2,
    "projection": "globe",
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "zoom": 3,
  },
  "monitor": {
    "branding": {
      "primaryColor": "#00AA55",
    },
    "description": "Full-featured climate intelligence dashboard with disaster tracking and AI analysis",
    "domain": "climate",
    "name": "Climate Intelligence",
    "slug": "climate-intelligence",
    "tags": [
      "climate",
      "environment",
      "sustainability",
      "disasters",
    ],
  },
  "panels": [
    {
      "config": {
        "categories": [
          "climate-news",
          "environment",
          "disasters",
        ],
        "maxItems": 50,
      },
      "displayName": "Climate News",
      "name": "climate-news",
      "position": 0,
      "type": "news-feed",
    },
    {
      "config": {
        "refreshInterval": 600,
      },
      "displayName": "Climate Brief",
      "name": "ai-brief",
      "position": 1,
      "type": "ai-brief",
    },
    {
      "config": {
        "entities": [
          "IPCC",
          "UNFCCC",
          "NASA",
          "NOAA",
          "WHO",
          "El Nino",
          "La Nina",
          "COP",
        ],
        "maxEntities": 20,
      },
      "displayName": "Key Organizations",
      "name": "entity-tracker",
      "position": 2,
      "type": "entity-tracker",
    },
    {
      "config": {},
      "displayName": "Source Status",
      "name": "service-status",
      "position": 3,
      "type": "service-status",
    },
  ],
  "sources": [
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "climate-news",
      "interval": 900,
      "language": "en",
      "name": "carbon-brief",
      "tags": [
        "climate",
        "science",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://www.carbonbrief.org/feed/",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "environment",
      "interval": 1800,
      "language": "en",
      "name": "phys-org-earth",
      "tags": [
        "earth",
        "science",
      ],
      "tier": 2,
      "type": "rss",
      "url": "https://phys.org/rss-feed/earth-news/",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "climate-news",
      "interval": 600,
      "language": "en",
      "name": "guardian-environment",
      "tags": [
        "climate",
        "environment",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://www.theguardian.com/environment/rss",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "disasters",
      "interval": 600,
      "language": "en",
      "name": "reliefweb-disasters",
      "tags": [
        "disasters",
        "humanitarian",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://reliefweb.int/updates/rss.xml",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "earth-observation",
      "interval": 3600,
      "language": "en",
      "name": "nasa-earth-observatory",
      "tags": [
        "nasa",
        "satellite",
      ],
      "tier": 2,
      "type": "rss",
      "url": "https://earthobservatory.nasa.gov/feeds/earth-observatory.rss",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "climate-data",
      "interval": 3600,
      "language": "en",
      "name": "noaa-climate",
      "tags": [
        "noaa",
        "climate-data",
      ],
      "tier": 2,
      "type": "rss",
      "url": "https://www.climate.gov/news-features/feed",
    },
  ],
  "theme": {
    "colors": {},
    "compactMode": false,
    "mode": "dark",
    "palette": "forest",
    "panelPosition": "right",
    "panelWidth": 380,
  },
  "version": "1",
  "views": [],
}
`;

