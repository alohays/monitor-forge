{
  "ai": {
    "analysis": {
      "customPrompt": "Focus on cyber threats, vulnerability disclosures, ransomware campaigns, APT activity, and critical infrastructure attacks. Highlight emerging threat actors and zero-day exploits.",
      "entityExtraction": true,
      "focalPointDetection": true,
      "sentimentAnalysis": true,
      "summarization": true,
    },
    "enabled": true,
    "fallbackChain": [
      "groq",
      "openrouter",
    ],
    "providers": {
      "groq": {
        "apiKeyEnv": "GROQ_API_KEY",
        "model": "llama-3.3-70b-versatile",
      },
      "openrouter": {
        "apiKeyEnv": "OPENROUTER_API_KEY",
        "model": "anthropic/claude-sonnet-4",
      },
    },
  },
  "backend": {
    "cache": {
      "provider": "memory",
      "ttlSeconds": 300,
    },
    "corsProxy": {
      "allowedDomains": [
        "*",
      ],
      "corsOrigins": [
        "*",
      ],
      "enabled": true,
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowSeconds": 60,
    },
  },
  "build": {
    "outDir": "dist",
    "target": "vercel",
