exports[`preset snapshot validation > health-full.json > passes MonitorForgeConfigSchema.parse() and matches snapshot 1`] = `
{
  "ai": {
    "analysis": {
      "customPrompt": "Focus on disease outbreaks, drug and vaccine approvals, pandemic preparedness, antimicrobial resistance, and public health emergencies. Highlight emerging pathogens and WHO declarations.",
      "entityExtraction": true,
      "focalPointDetection": true,
      "sentimentAnalysis": true,
      "summarization": true,
    },
    "enabled": true,
    "fallbackChain": [
      "groq",
      "openrouter",
    ],
    "providers": {
      "groq": {
        "apiKeyEnv": "GROQ_API_KEY",
        "model": "llama-3.3-70b-versatile",
      },
      "openrouter": {
        "apiKeyEnv": "OPENROUTER_API_KEY",
        "model": "anthropic/claude-sonnet-4",
      },
    },
  },
  "backend": {
    "cache": {
      "provider": "memory",
      "ttlSeconds": 300,
    },
    "corsProxy": {
      "allowedDomains": [
        "*",
      ],
      "corsOrigins": [
        "*",
      ],
      "enabled": true,
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowSeconds": 60,
    },
  },
  "build": {
    "outDir": "dist",
    "target": "vercel",
  },
  "layers": [
    {
      "category": "infrastructure",
      "color": "#00AA55",
      "data": {
        "path": "data/geo/who-regions.geojson",
        "source": "static",
      },
      "defaultVisible": false,
      "displayName": "WHO Regional Offices",
      "name": "who-regions",
      "type": "points",
    },
  ],
  "map": {
    "atmosphericGlow": true,
    "center": [
      0,
      20,
    ],
    "dayNightOverlay": true,
    "idleRotation": true,
    "idleRotationSpeed": 0.5,
    "maxZoom": 18,
    "minZoom": 2,
    "projection": "globe",
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "zoom": 3,
  },
  "monitor": {
    "branding": {
      "primaryColor": "#0099DD",
    },
    "description": "Full-featured global health intelligence dashboard with disease tracking and AI analysis",
    "domain": "health",
    "name": "Health Intelligence",
    "slug": "health-intelligence",
    "tags": [
      "health",
      "medicine",
      "public-health",
      "surveillance",
      "research",
    ],
  },
  "panels": [
    {
      "config": {
        "categories": [
          "health-news",
          "surveillance",
        ],
        "maxItems": 50,
      },
      "displayName": "Health News",
      "name": "health-news",
      "position": 0,
      "type": "news-feed",
    },
    {
      "config": {
        "refreshInterval": 600,
      },
      "displayName": "Health Brief",
      "name": "ai-brief",
      "position": 1,
      "type": "ai-brief",
    },
    {
      "config": {
        "entities": [
          "WHO",
          "CDC",
          "FDA",
          "EMA",
          "Pfizer",
          "Moderna",
          "H5N1",
          "MPOX",
        ],
        "maxEntities": 20,
      },
      "displayName": "Key Entities",
      "name": "entity-tracker",
      "position": 2,
      "type": "entity-tracker",
    },
    {
      "config": {},
      "displayName": "Source Status",
      "name": "service-status",
      "position": 3,
      "type": "service-status",
    },
  ],
  "sources": [
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "health-news",
      "interval": 1800,
      "language": "en",
      "name": "who-news",
      "tags": [
        "who",
        "global-health",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://www.who.int/feeds/entity/news/en/rss.xml",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "health-news",
      "interval": 600,
      "language": "en",
      "name": "stat-news",
      "tags": [
        "medicine",
        "pharma",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://www.statnews.com/feed/",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "health-news",
      "interval": 900,
      "language": "en",
      "name": "nih-news",
      "tags": [
        "research",
        "nih",
      ],
      "tier": 1,
      "type": "rss",
      "url": "https://www.nih.gov/news-events/news-releases/feed",
    },
    {
      "authHeader": "Authorization",
      "cacheTtl": 300,
      "category": "research",
      "interval": 3600,
      "language": "en",
