{
  "ai": {
    "analysis": {
      "customPrompt": "Focus on geopolitical tensions, military movements, diplomatic developments, sanctions, and territorial disputes. Highlight escalation/de-escalation signals.",
      "entityExtraction": true,
      "focalPointDetection": true,
      "sentimentAnalysis": true,
      "summarization": true,
    },
    "enabled": true,
    "fallbackChain": [
      "groq",
      "openrouter",
    ],
    "providers": {
      "groq": {
        "apiKeyEnv": "GROQ_API_KEY",
        "model": "llama-3.3-70b-versatile",
      },
      "openrouter": {
        "apiKeyEnv": "OPENROUTER_API_KEY",
        "model": "anthropic/claude-sonnet-4",
      },
    },
  },
  "backend": {
    "cache": {
      "provider": "memory",
      "ttlSeconds": 300,
    },
    "corsProxy": {
      "allowedDomains": [
        "*",
      ],
      "corsOrigins": [
        "*",
      ],
      "enabled": true,
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowSeconds": 60,
    },
  },
  "build": {
    "outDir": "dist",
    "target": "vercel",
  },
  "layers": [
    {
      "category": "security",
      "color": "#FF4444",
