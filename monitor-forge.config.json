{
  "monitor": {
    "name": "Tech Monitor",
    "slug": "tech-monitor",
    "description": "Minimal tech industry intelligence dashboard",
    "domain": "technology",
    "tags": [
      "tech",
      "ai",
      "startups"
    ],
    "branding": {
      "primaryColor": "#0052CC"
    }
  },
  "sources": [
    {
      "name": "hackernews-rss",
      "type": "rss",
      "url": "https://hnrss.org/frontpage",
      "category": "tech-news",
      "tier": 1,
      "interval": 300,
      "language": "en",
      "tags": [
        "tech",
        "startups"
      ]
    },
    {
      "name": "techcrunch-rss",
      "type": "rss",
      "url": "https://techcrunch.com/feed/",
      "category": "tech-news",
      "tier": 1,
      "interval": 600,
      "language": "en",
      "tags": [
        "tech",
        "startups",
        "vc"
      ]
    },
    {
      "name": "ars-technica",
      "type": "rss",
      "url": "https://feeds.arstechnica.com/arstechnica/index",
      "category": "tech-news",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": [
        "tech",
        "science"
      ]
    }
  ],
  "layers": [],
  "panels": [
    {
      "name": "tech-news",
      "type": "news-feed",
      "displayName": "Tech News",
      "position": 0,
      "config": {
        "categories": [
          "tech-news"
        ],
        "maxItems": 30
      }
    },
    {
      "name": "ai-brief",
      "type": "ai-brief",
      "displayName": "AI Brief",
      "position": 1,
      "config": {
        "refreshInterval": 900
      }
    },
    {
      "name": "market-ticker",
      "type": "market-ticker",
      "displayName": "Market Ticker",
      "position": 2,
      "config": {}
    },
    {
      "name": "instability-index",
      "type": "instability-index",
      "displayName": "Instability Index",
      "position": 3,
      "config": {}
    }
  ],
  "views": [],
  "ai": {
    "enabled": false,
    "fallbackChain": [
      "groq"
    ],
    "providers": {
      "groq": {
        "model": "llama-3.3-70b-versatile",
        "apiKeyEnv": "GROQ_API_KEY"
      }
    },
    "analysis": {
      "summarization": true,
      "entityExtraction": true,
      "sentimentAnalysis": false,
      "focalPointDetection": false
    }
  },
  "map": {
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "center": [
      -95,
      38
    ],
    "zoom": 4,
    "minZoom": 2,
    "maxZoom": 18,
    "projection": "mercator",
    "dayNightOverlay": false,
    "atmosphericGlow": true,
    "idleRotation": true,
    "idleRotationSpeed": 0.5
  },
  "backend": {
    "cache": {
      "provider": "memory",
      "ttlSeconds": 300
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowSeconds": 60
    },
    "corsProxy": {
      "enabled": true,
      "allowedDomains": [
        "*"
      ],
      "corsOrigins": [
        "*"
      ]
    }
  },
  "build": {
    "target": "vercel",
    "outDir": "dist"
  }
}
