{
  "_meta": {
    "category": "geopolitics",
    "difficulty": "intermediate",
    "requires_api_keys": ["GROQ_API_KEY"],
    "optional_api_keys": ["OPENROUTER_API_KEY"],
    "preview_description": "Full geopolitical intelligence with conflict zone mapping and instability index"
  },
  "monitor": {
    "name": "Geopolitical Intelligence",
    "slug": "geopolitical-intelligence",
    "description": "Full-featured geopolitical intelligence dashboard with conflict tracking and AI analysis",
    "domain": "geopolitics",
    "tags": ["geopolitics", "conflict", "diplomacy", "security", "osint"],
    "branding": {
      "primaryColor": "#CC0000"
    }
  },
  "sources": [
    {
      "name": "bbc-world",
      "type": "rss",
      "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
      "category": "world-news",
      "tier": 1,
      "interval": 300,
      "language": "en",
      "tags": ["world"]
    },
    {
      "name": "reuters-world",
      "type": "rss",
      "url": "https://www.reutersagency.com/feed/?taxonomy=best-topics&post_type=best",
      "category": "world-news",
      "tier": 1,
      "interval": 300,
      "language": "en",
      "tags": ["world"]
    },
    {
      "name": "aljazeera",
      "type": "rss",
      "url": "https://www.aljazeera.com/xml/rss/all.xml",
      "category": "world-news",
      "tier": 1,
      "interval": 600,
      "language": "en",
      "tags": ["world", "middle-east"]
    },
    {
      "name": "guardian-world",
      "type": "rss",
      "url": "https://www.theguardian.com/world/rss",
      "category": "world-news",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": ["world"]
    },
    {
      "name": "ap-news-world",
      "type": "rss",
      "url": "https://rsshub.app/apnews/topics/world-news",
      "category": "world-news",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": ["world"]
    },
    {
      "name": "foreign-affairs",
      "type": "rss",
      "url": "https://www.foreignaffairs.com/rss.xml",
      "category": "analysis",
      "tier": 1,
      "interval": 3600,
      "language": "en",
      "tags": ["analysis", "policy"]
    },
    {
      "name": "war-on-rocks",
      "type": "rss",
      "url": "https://warontherocks.com/feed/",
      "category": "security",
      "tier": 2,
      "interval": 3600,
      "language": "en",
      "tags": ["defense", "security"]
    },
    {
      "name": "gdelt-events",
      "type": "rest-api",
      "url": "https://api.gdeltproject.org/api/v2/doc/doc?query=conflict&mode=artlist&maxrecords=50&format=json",
      "category": "events",
      "tier": 2,
      "interval": 900,
      "language": "en",
      "tags": ["events", "conflict"]
    }
  ],
  "layers": [
    {
      "name": "conflict-zones",
      "type": "heatmap",
      "displayName": "Conflict Zones",
      "color": "#FF4444",
      "data": { "source": "static", "path": "data/geo/conflict-zones.geojson" },
      "defaultVisible": true,
      "category": "security"
    }
  ],
  "panels": [
    {
      "name": "world-news",
      "type": "news-feed",
      "displayName": "World News Feed",
      "position": 0,
      "config": {
        "categories": ["world-news", "security"],
        "maxItems": 50
      }
    },
    {
      "name": "situation-brief",
      "type": "ai-brief",
      "displayName": "Situation Brief",
      "position": 1,
      "config": {
        "refreshInterval": 600
      }
    },
    {
      "name": "entity-tracker",
      "type": "entity-tracker",
      "displayName": "Key Actors",
      "position": 2,
      "config": {
        "entities": ["NATO", "UN", "EU", "China", "Russia", "USA", "Iran", "North Korea"],
        "maxEntities": 20
      }
    },
    {
      "name": "instability-index",
      "type": "instability-index",
      "displayName": "Instability Index",
      "position": 3,
      "config": {}
    },
    {
      "name": "service-status",
      "type": "service-status",
      "displayName": "Source Status",
      "position": 4,
      "config": {}
    }
  ],
  "views": [
    {
      "name": "overview",
      "displayName": "Overview",
      "panels": ["world-news", "situation-brief"],
      "default": true
    },
    {
      "name": "analysis",
      "displayName": "Analysis",
      "panels": ["situation-brief", "entity-tracker", "instability-index"]
    },
    {
      "name": "operations",
      "displayName": "Operations",
      "panels": ["world-news", "service-status"]
    }
  ],
  "ai": {
    "enabled": true,
    "fallbackChain": ["groq", "openrouter"],
    "providers": {
      "groq": {
        "model": "llama-3.3-70b-versatile",
        "apiKeyEnv": "GROQ_API_KEY"
      },
      "openrouter": {
        "model": "anthropic/claude-sonnet-4",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      }
    },
    "analysis": {
      "summarization": true,
      "entityExtraction": true,
      "sentimentAnalysis": true,
      "focalPointDetection": true,
      "customPrompt": "Focus on geopolitical tensions, military movements, diplomatic developments, sanctions, and territorial disputes. Highlight escalation/de-escalation signals."
    }
  },
  "map": {
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "center": [30, 30],
    "zoom": 3,
    "projection": "globe",
    "dayNightOverlay": true,
    "atmosphericGlow": true,
    "idleRotation": true,
    "idleRotationSpeed": 0.3
  },
  "theme": {
    "palette": "midnight"
  }
}
