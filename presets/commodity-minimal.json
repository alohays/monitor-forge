{
  "version": "1",
  "_meta": {
    "category": "commodity",
    "difficulty": "beginner",
    "requires_api_keys": [],
    "optional_api_keys": [],
    "preview_description": "Track global commodity markets including oil, metals, and agriculture"
  },
  "monitor": {
    "name": "Commodity Monitor",
    "slug": "commodity-monitor",
    "description": "Minimal commodity market tracking dashboard",
    "domain": "commodities",
    "tags": [
      "commodities",
      "energy",
      "metals"
    ]
  },
  "sources": [
    {
      "name": "metal-miner",
      "type": "rss",
      "url": "https://agmetalminer.com/feed/",
      "category": "commodities",
      "tier": 3,
      "interval": 600,
      "language": "en",
      "tags": [
        "metals",
        "procurement"
      ]
    },
    {
      "name": "reuters-commodities",
      "type": "rss",
      "url": "https://news.google.com/rss/search?q=site:reuters.com+commodities&hl=en-US&gl=US&ceid=US:en",
      "category": "commodities",
      "tier": 1,
      "interval": 300,
      "language": "en",
      "tags": [
        "wire-service",
        "markets"
      ]
    },
    {
      "name": "oilprice-com",
      "type": "rss",
      "url": "https://oilprice.com/rss/main",
      "category": "commodities",
      "tier": 2,
      "interval": 300,
      "language": "en",
      "tags": [
        "oil",
        "gas",
        "energy"
      ]
    },
    {
      "name": "commodity-weather-group",
      "type": "rss",
      "url": "https://news.google.com/rss/search?q=commodity+weather+agriculture&hl=en-US&gl=US&ceid=US:en",
      "category": "commodities",
      "tier": 3,
      "interval": 900,
      "language": "en",
      "tags": [
        "weather",
        "agriculture"
      ]
    },
    {
      "name": "google-news-commodities",
      "type": "rss",
      "url": "https://news.google.com/rss/search?q=commodity+markets&hl=en-US&gl=US&ceid=US:en",
      "category": "commodities",
      "tier": 4,
      "interval": 600,
      "language": "en",
      "tags": [
        "aggregator"
      ]
    },
    {
      "name": "utility-dive",
      "type": "rss",
      "url": "https://www.utilitydive.com/feeds/news/",
      "category": "energy",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": [
        "utilities",
        "grid"
      ]
    },
    {
      "name": "energy-monitor",
      "type": "rss",
      "url": "https://www.energymonitor.ai/feed/",
      "category": "energy",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": [
        "transition",
        "analysis"
      ]
    }
  ],
  "layers": [],
  "panels": [
    {
      "name": "commodity-news",
      "type": "news-feed",
      "displayName": "Commodity News",
      "position": 0,
      "config": {
        "categories": [
          "commodities",
          "energy"
        ],
        "maxItems": 30
      }
    },
    {
      "name": "market-ticker",
      "type": "market-ticker",
      "displayName": "Market Ticker",
      "position": 1,
      "config": {}
    }
  ],
  "views": [
    {
      "name": "overview",
      "displayName": "Overview",
      "panels": [
        "commodity-news",
        "market-ticker"
      ],
      "default": true
    }
  ],
  "ai": {
    "enabled": false
  },
  "map": {
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "center": [
      0,
      20
    ],
    "zoom": 3,
    "projection": "mercator"
  },
  "theme": {
    "palette": "sunset"
  }
}
