{
  "_meta": {
    "category": "technology",
    "difficulty": "beginner",
    "requires_api_keys": ["GROQ_API_KEY"],
    "optional_api_keys": [],
    "preview_description": "Track tech news from Hacker News, TechCrunch, and Ars Technica"
  },
  "monitor": {
    "name": "Tech Monitor",
    "slug": "tech-monitor",
    "description": "Minimal tech industry intelligence dashboard",
    "domain": "technology",
    "tags": ["tech", "ai", "startups"]
  },
  "sources": [
    {
      "name": "hackernews-rss",
      "type": "rss",
      "url": "https://hnrss.org/frontpage",
      "category": "tech-news",
      "tier": 1,
      "interval": 300,
      "language": "en",
      "tags": ["tech", "startups"]
    },
    {
      "name": "techcrunch-rss",
      "type": "rss",
      "url": "https://techcrunch.com/feed/",
      "category": "tech-news",
      "tier": 1,
      "interval": 600,
      "language": "en",
      "tags": ["tech", "startups", "vc"]
    },
    {
      "name": "ars-technica",
      "type": "rss",
      "url": "https://feeds.arstechnica.com/arstechnica/index",
      "category": "tech-news",
      "tier": 2,
      "interval": 600,
      "language": "en",
      "tags": ["tech", "science"]
    }
  ],
  "layers": [],
  "panels": [
    {
      "name": "tech-news",
      "type": "news-feed",
      "displayName": "Tech News",
      "position": 0,
      "config": {
        "categories": ["tech-news"],
        "maxItems": 30
      }
    },
    {
      "name": "ai-brief",
      "type": "ai-brief",
      "displayName": "AI Brief",
      "position": 1,
      "config": {
        "refreshInterval": 900
      }
    }
  ],
  "views": [
    {
      "name": "overview",
      "displayName": "Overview",
      "panels": ["tech-news", "ai-brief"],
      "default": true
    }
  ],
  "ai": {
    "enabled": true,
    "fallbackChain": ["groq"],
    "providers": {
      "groq": {
        "model": "llama-3.3-70b-versatile",
        "apiKeyEnv": "GROQ_API_KEY"
      }
    },
    "analysis": {
      "summarization": true,
      "entityExtraction": true,
      "sentimentAnalysis": false
    }
  },
  "map": {
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "center": [-95, 38],
    "zoom": 4,
    "projection": "mercator"
  },
  "theme": {
    "palette": "default"
  }
}
