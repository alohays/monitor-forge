  "layers": [],
  "panels": [
    {
      "name": "good-news",
      "type": "news-feed",
      "displayName": "Good News",
      "position": 0,
      "config": {
        "categories": [
          "happy",
          "climate",
          "energy",
          "tech"
        ],
        "maxItems": 50
      }
    },
    {
      "name": "bright-spots",
      "type": "ai-brief",
      "displayName": "Bright Spots Brief",
      "position": 1,
      "config": {
        "refreshInterval": 600
      }
    }
  ],
  "views": [
    {
      "name": "overview",
      "displayName": "All Good News",
      "panels": [
        "good-news",
        "bright-spots"
      ],
      "default": true
    },
    {
      "name": "science-innovation",
      "displayName": "Science & Innovation",
      "panels": [
        "good-news",
        "bright-spots"
      ]
    },
    {
      "name": "people-planet",
      "displayName": "People & Planet",
      "panels": [
        "good-news",
        "bright-spots"
      ]
    }
  ],
  "ai": {
    "enabled": true,
    "fallbackChain": [
      "groq"
    ],
    "providers": {
      "groq": {
        "model": "llama-3.3-70b-versatile",
        "apiKeyEnv": "GROQ_API_KEY"
      }
    },
    "analysis": {
      "summarization": true,
      "entityExtraction": true,
      "sentimentAnalysis": false,
      "focalPointDetection": false,
      "customPrompt": "Focus on bright spots: scientific breakthroughs, conservation wins, community solutions, renewable energy milestones, and stories of human progress and resilience."
    }
  },
  "map": {
    "style": "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json",
    "center": [
      0,
      20
    ],
    "zoom": 3,
    "projection": "mercator"
  },
  "theme": {
    "palette": "forest"
  }
}
